{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd app/frontend && pnpm install --frozen-lockfile",
  "buildCommand": "cd app/frontend && pnpm build",
  "outputDirectory": "app/frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

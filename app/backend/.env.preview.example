APP_ENV=preview
DEBUG=false
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/uahub_preview
JWT_SECRET_KEY=replace-in-preview-secret-store
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
BACKEND_PUBLIC_URL=https://api-preview.example.com
FRONTEND_PUBLIC_URL=https://preview.example.com
ALLOWED_DOMAINS=preview.example.com,api-preview.example.com

# Auth / OIDC secrets
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Billing secrets
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Supabase secret placeholders
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Preview safety defaults
DEV_AUTH_ENABLED=false
MGX_LOAD_MOCK_DATA=false

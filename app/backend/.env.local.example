APP_ENV=local
DEV_AUTH_ENABLED=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/uahub_local
JWT_SECRET_KEY=change-me-before-any-shared-env
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
FRONTEND_PUBLIC_URL=http://localhost:3000
ADMIN_USER_ID=dev-admin
ADMIN_USER_EMAIL=admin@local.test
MGX_LOAD_MOCK_DATA=true

# Supabase placeholders for local development
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Optional local integrations
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Release gate: before production release confirm the following
# [ ] DEV_AUTH_ENABLED removed or set to false in non-local environments
# [ ] Local admin test identity removed from deployed environments
# [ ] Test-only JWT secret replaced with production secret management

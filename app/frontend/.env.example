VITE_TURNSTILE_SITE_KEY=

# Backend environment variables required for the hosted OIDC auth flow.
# Set these in backend deployment/runtime, not in Vite client code:
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPE=
# JWT_SECRET_KEY=
# TURNSTILE_SECRET_KEY=
# OIDC_ENABLE_GOOGLE_AUTH=true
# OIDC_ENABLE_APPLE_AUTH=true
# OIDC_ENABLE_EMAIL_AUTH=true
# OIDC_ENABLE_PHONE_AUTH=false
# OIDC_GOOGLE_CONNECTION=
# OIDC_APPLE_CONNECTION=
# OIDC_EMAIL_CONNECTION=
# OIDC_PHONE_CONNECTION=
# OIDC_CONNECTION_PARAM=connection
# OIDC_SCREEN_HINT_PARAM=screen_hint
# OIDC_SIGNUP_HINT_VALUE=signup
# OIDC_LOGIN_HINT_VALUE=login
# OIDC_REQUIRE_VERIFIED_EMAIL=true
